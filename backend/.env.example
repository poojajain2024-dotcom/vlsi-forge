APP_NAME=VLSI Forge API
ENV=production
# Local dev can use SQLite: sqlite+pysqlite:///./vlsiapp.db
# Production: paste the hosted Postgres URL (Render/Railway give a postgres:// URL).
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/vlsiapp
JWT_SECRET=replace_me_with_a_long_random_secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440
# Comma-separated frontend origins. In production use your real domain(s):
# https://vlsiforge.app,https://www.vlsiforge.app
CORS_ORIGINS=http://localhost:5500,http://localhost:8081
